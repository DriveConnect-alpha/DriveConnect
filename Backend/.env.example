# --- Servidor ---
PORT=3000
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:8080
NODE_ENV=development
HTTPS_BEHIND_PROXY=true
API_BASE_PATH=
CORS_ORIGIN=*
CORS_METHODS=GET, POST, PUT, PATCH, DELETE, OPTIONS
CORS_HEADERS=Content-Type, Authorization, x-api-key

# --- Banco de Dados (PostgreSQL) ---
# Formato: postgresql://usuario:senha@localhost:5432/nome_do_banco
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/driveconnect?schema=public"

# --- Pagamentos (InfinitePay) ---
INFINITEPAY_HANDLE=sua_infinite_tag
INFINITEPAY_WEBHOOK_SECRET=sua_chave_secreta_aqui
PAGAMENTO_EXPIRACAO_MINUTOS=10

# --- Segurança (Argon2id) ---
#Argon2id configura a memória e tempo de permanencia que o servidor usa para validar as senhas 1020 = 1mib
ARGON2_MEMORY_COST=1024 #1MiB
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1

# --- Chave API Pública ---
PUBLIC_API_KEY=driveconnect_public_key_aqui

# --- WhatsApp Cloud API ---
WHATSAPP_VERIFY_TOKEN=seu_token_de_verificacao
WHATSAPP_ACCESS_TOKEN=seu_token_de_acesso
WHATSAPP_PHONE_NUMBER_ID=seu_phone_number_id
WHATSAPP_APP_SECRET=seu_app_secret
WHATSAPP_REQUIRE_SIGNATURE=0
WHATSAPP_GRAPH_API_VERSION=v19.0
WHATSAPP_RATE_LIMIT_WINDOW_MS=60000
WHATSAPP_RATE_LIMIT_MAX=120
WHATSAPP_DEDUPE_TTL_MS=600000
WHATSAPP_HISTORY_LIMIT=12
WHATSAPP_QUICK_REPLY_MS=0
WHATSAPP_QUICK_REPLY_TEXT=
WHATSAPP_TIMEOUT_MS=10000

# --- OpenAI / RAG ---
OPENAI_API_KEY=sua_openai_api_key
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_TEMPERATURE=0.1
OPENAI_MAX_TOKENS=220
OPENAI_TIMEOUT_MS=8000

# --- RAG (PGVector) ---
RAG_COLLECTION=driveconnect
RAG_PG_TABLE=langchain_pg_embedding
RAG_COLLECTION_TABLE=langchain_pg_collection
RAG_CONTENT_COLUMN=document
RAG_METADATA_COLUMN=metadata
RAG_VECTOR_COLUMN=embedding
RAG_ID_COLUMN=id
RAG_KNOWLEDGE_DIR=knowledge
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=160
RAG_TOP_K=4
RAG_FETCH_K=12
RAG_MMR_LAMBDA=0.5
RAG_SEARCH_TYPE=mmr
RAG_MAX_CONTEXT_CHARS=6000
RAG_WIPE_BEFORE_INGEST=0
